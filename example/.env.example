# Plain values
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=00000000-0000-0000-0000-000000000000;IngestionEndpoint=https://example.in.applicationinsights.azure.com/

# Slot-pinned (sticks to the deployment slot)
AZURE_CLIENT_ID=f36f554d-cece-42d9-a833-ba82405863a6 # @slot

# Secret — vault/secret name resolved from config (`az-env config vault.name <name>`)
AZURE_CLIENT_SECRET=changeme # @secret @slot

# Secret — explicit override of vault and secret name
DATABASE_PASSWORD=changeme # @secret(vault=ominiticketsvault,name=DB-PASSWORD)
